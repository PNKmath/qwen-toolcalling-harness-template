# Copy to .env.harness and edit values for your machine

# Binary path
MLX_OPENAI_SERVER_BIN=$HOME/.mlx-env/bin/mlx-openai-server

# Shared host/log
QWEN_HOST=127.0.0.1
QWEN_LOG_DIR=$HOME/.mlx-model-control/logs

# 4bit
QWEN27_4BIT_MODEL_PATH=$HOME/MLX_Models/Qwen3.6-27B-UD-MLX-4bit
QWEN27_4BIT_SERVED_MODEL_NAME=Qwen3.6-27B-UD-MLX-4bit
QWEN27_4BIT_PORT=8016

# 6bit
QWEN27_6BIT_MODEL_PATH=$HOME/MLX_Models/Qwen3.6-27B-UD-MLX-6bit
QWEN27_6BIT_SERVED_MODEL_NAME=Qwen3.6-27B-UD-MLX-6bit
QWEN27_6BIT_PORT=8018

# 8bit
QWEN27_8BIT_MODEL_PATH=$HOME/MLX_Models/Qwen3.6-27B-MLX-8bit
QWEN27_8BIT_SERVED_MODEL_NAME=Qwen3.6-27B-MLX-8bit
QWEN27_8BIT_PORT=8020
